def replace_recursively(
        current_node,
        root_metadata,
        g_env_map,
        env_name_clean,
        db_name_lower,
        current_key=None,
        parent_dict=None):

    if root_metadata is None:
        root_metadata = current_node

    conditional_rules = {
        'destination_database': lambda v, context: handle_destination_database(
            v, root_metadata, g_env_map, env_name_clean, context
        ),
        'destination_warehouse': lambda v, context: handle_destination_warehouse(
            v, root_metadata, g_env_map, env_name_clean, context
        ),
        'source_database': lambda v, context: handle_source_database(
            v, root_metadata, g_env_map, env_name_clean, context
        ),
        'source_warehouse': lambda v, context: handle_source_warehouse(
            v, root_metadata, g_env_map, env_name_clean, context
        ),
        'ftp_host_name': lambda v, context: handle_pattern_fields(
            v, root_metadata, g_env_map, env_name_clean,
            db_name_lower, context
        ),
        'default_ftp_host_name': lambda v, context: handle_pattern_fields(
            v, root_metadata, g_env_map, env_name_clean,
            db_name_lower, context
        ),
        'to_uat': lambda v, context: handle_pattern_fields(
            v, root_metadata, g_env_map, env_name_clean,
            db_name_lower, context
        ),
        'default_ftp_root_folder': lambda v, context: handle_pattern_fields(
            v, root_metadata, g_env_map, env_name_clean,
            db_name_lower, context
        ),
        'root_folder': lambda v, context: handle_pattern_fields(
            v, root_metadata, g_env_map, env_name_clean,
            db_name_lower, context
        ),
        'workspace_id': lambda v, context: handle_pattern_fields(
            v, root_metadata, g_env_map, env_name_clean,
            db_name_lower, context
        ),
        'resource_id': lambda v, context: handle_pattern_fields(
            v, root_metadata, g_env_map, env_name_clean,
            db_name_lower, context
        )
    }

    if isinstance(current_node, dict):

        return {
            k: replace_recursively(
                v,
                root_metadata,
                g_env_map,
                env_name_clean,
                db_name_lower,
                current_key=k,
                parent_dict=current_node
            )
            for k, v in current_node.items()
        }

    elif isinstance(current_node, list):

        return [
            replace_recursively(
                item,
                root_metadata,
                g_env_map,
                env_name_clean,
                db_name_lower,
                current_key=current_key,
                parent_dict=parent_dict
            )
            for item in current_node
        ]

    elif isinstance(current_node, str):

        #
        # Special rules
        #
        rule = conditional_rules.get(current_key)

        if rule:
            return rule(
                current_node,
                context=parent_dict
            )

        #
        # Procedure handling
        #
        if current_key == 'post_execution_procedure':
            return replace_db_in_procedurename_per_env(
                current_node,
                g_env_map.get("Database", {}),
                env_name_clean
            )

        #
        # Generic replacement
        #
        node_lower = current_node.lower()

        entity_name = ""

        if (
            isinstance(parent_dict, dict)
            and "source_entity" in parent_dict
        ):
            entity_name = (
                parent_dict["source_entity"]
                .lower()
            )

        #
        # Only use mapping section matching current key
        #
        category_map = (
            g_env_map.get(current_key)
            or g_env_map.get(
                str(current_key).lower()
            )
        )

        if not isinstance(category_map, dict):
            return current_node

        lookups_to_try = []

        #
        # Priority 1
        #
        if db_name_lower and entity_name:
            lookups_to_try.append(
                f"[{db_name_lower}]"
                f"[{entity_name}]"
                f"[{node_lower}]"
            )

        #
        # Priority 2
        #
        if db_name_lower:
            lookups_to_try.append(
                f"[{db_name_lower}]"
                f"[{node_lower}]"
            )

        #
        # Priority 3
        #
        if entity_name:
            lookups_to_try.append(
                f"[{entity_name}]"
                f"[{node_lower}]"
            )

        #
        # Priority 4
        #
        lookups_to_try.extend([
            node_lower,
            current_node
        ])

        lowercase_mappings = {
            str(k).lower(): v
            for k, v in category_map.items()
        }

        for lookup in lookups_to_try:

            lookup = lookup.lower()

            if lookup not in lowercase_mappings:
                continue

            env_values = lowercase_mappings[lookup]

            if (
                isinstance(env_values, dict)
                and env_name_clean in env_values
            ):

                resolved_val = (
                    env_values[env_name_clean]
                )

                if (
                    current_key
                    and any(
                        x in current_key.lower()
                        for x in [
                            "database",
                            "warehouse"
                        ]
                    )
                ):
                    resolved_val = (
                        str(resolved_val)
                        .upper()
                    )

                logging.info(
                    f"Mapped "
                    f"{current_key}: "
                    f"{current_node} -> "
                    f"{resolved_val}"
                )

                return resolved_val

        return current_node

    return current_node
