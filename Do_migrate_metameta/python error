def replace_db_in_procedurename_per_env(procedure_name: str, env_map_database: dict, env: str):
    parts = procedure_name.strip().split('.')
    if len(parts) == 3:
        db_val = parts[0]
        if db_val.lower() in env_map_database:
            mapped_db = env_map_database[db_val.lower()][env]
            return f"{mapped_db}.{parts[1]}.{parts[2]}".upper()
    return procedure_name.upper()

def find_entity_meta_meta(meta, entity_name):
    for entity in meta.get('entities', []):
        if entity['source_entity'].lower() == entity_name.lower():
            return entity
    return None


# -----------------------------------------------------------------
# COUPLING-FREE ENVIRONMENT MAPPING RULES
# -----------------------------------------------------------------
def handle_destination_database(val, root_metadata, g_env_map, env_name_clean, context=None, current_key=None):
    if root_metadata.get('source_type', '').lower() != 'snowflake':
        if "Database" in g_env_map and val.lower() in g_env_map["Database"]:
            return g_env_map["Database"][val.lower()][env_name_clean].upper()
    return val

def handle_destination_warehouse(val, root_metadata, g_env_map, env_name_clean, context=None, current_key=None):
    if root_metadata.get('destination_type', '').lower() == "sql server":
        if "Server" in g_env_map and val.lower() in g_env_map["Server"]:
            return g_env_map["Server"][val.lower()][env_name_clean]
    else:
        if "Warehouse" in g_env_map and val.lower() in g_env_map["Warehouse"]:
            return g_env_map["Warehouse"][val.lower()][env_name_clean].upper()
    return val

def handle_source_database(val, root_metadata, g_env_map, env_name_clean, context=None, current_key=None):
    if root_metadata.get('source_type', '').lower() == "snowflake":
        if "Database" in g_env_map and val.lower() in g_env_map["Database"]:
            return g_env_map["Database"][val.lower()][env_name_clean].upper()
    else:
        if "SQLDatabase" in g_env_map and val.lower() in g_env_map["SQLDatabase"]:
            return g_env_map["SQLDatabase"][val.lower()][env_name_clean]
    return val

def handle_source_warehouse(val, root_metadata, g_env_map, env_name_clean, context=None, current_key=None):
    if root_metadata.get('source_type', '').lower() == "snowflake":
        if "Warehouse" in g_env_map and val.lower() in g_env_map["Warehouse"]:
            return g_env_map["Warehouse"][val.lower()][env_name_clean].upper()
    return val

def handle_pattern_fields(val, root_metadata, g_env_map, env_name_clean, db_name_lower, context=None, current_key=None):
    if not isinstance(val, str) or not current_key:
        return val
    
    val_lower = val.lower()
    key_lower = current_key.lower()
    
    # 1. STRICT CATEGORY FILTER: Look directly for the matching section name
    target_mappings = None
    for category_name, mappings in g_env_map.items():
        if category_name.lower() == key_lower:
            target_mappings = mappings
            break
            
    if not target_mappings and 'server' in key_lower and 'Server' in g_env_map:
        target_mappings = g_env_map['Server']

    # 2. If no category exists in global map for this key, exit cleanly!
    if not target_mappings or not isinstance(target_mappings, dict):
        return val

    entity_name = ''
    if isinstance(context, dict):
        entity_name = context.get('source_entity', '').lower()
    
    lookups_to_try = []
    if db_name_lower:
        lookups_to_try.append(f'[{db_name_lower}]{val_lower}') 
        lookups_to_try.append(f'[{db_name_lower}][{val_lower}]') 
    if db_name_lower and entity_name:
        lookups_to_try.append(f'[{db_name_lower}][{entity_name}][{val_lower}]')
    if entity_name:
        lookups_to_try.append(f'[{entity_name}][{val_lower}]')
    lookups_to_try.extend([val_lower, val])

    lowercase_mappings = {str(k).lower(): v for k, v in target_mappings.items()}
    for lookup in lookups_to_try:
        if lookup in lowercase_mappings:
            resolved_val = lowercase_mappings[lookup][env_name_clean]
            if resolved_val.lower() == val_lower:
                return val
            return resolved_val
            
    return val


# -----------------------------------------------------------------
# DECOUPLED RECURSION TRANSLATION ENGINE
# -----------------------------------------------------------------
def replace_recursively(current_node, root_metadata, g_env_map, env_name_clean, db_name_lower, current_key=None, parent_dict=None):
    if root_metadata is None:
        root_metadata = current_node

    if isinstance(current_node, dict):
        return {k: replace_recursively(v, root_metadata, g_env_map, env_name_clean, db_name_lower, current_key=k, parent_dict=current_node) for k, v in current_node.items()}
    elif isinstance(current_node, list):
        return [replace_recursively(item, root_metadata, g_env_map, env_name_clean, db_name_lower, current_key=current_key, parent_dict=parent_dict) for item in current_node]
    elif isinstance(current_node, str):
        if current_key == 'external_stage_name':
            return f"{env_name_clean.strip().upper()}_CSV_STAGE"
        if current_key == 'post_execution_procedure':
            return replace_db_in_procedurename_per_env(current_node, g_env_map.get("Database", {}), env_name_clean)

        conditional_rules = {
            'destination_database': lambda v, context: handle_destination_database(v, root_metadata, g_env_map, env_name_clean, context, current_key),
            'destination_warehouse': lambda v, context: handle_destination_warehouse(v, root_metadata, g_env_map, env_name_clean, context, current_key),
            'source_database': lambda v, context: handle_source_database(v, root_metadata, g_env_map, env_name_clean, context, current_key),
            'source_warehouse': lambda v, context: handle_source_warehouse(v, root_metadata, g_env_map, env_name_clean, context, current_key),
            'outbound_database': lambda v, context: handle_destination_database(v, root_metadata, g_env_map, env_name_clean, context, current_key),
            'archive_database': lambda v, context: handle_source_database(v, root_metadata, g_env_map, env_name_clean, context, current_key),
            'hwm_server': lambda v, context: handle_pattern_fields(v, root_metadata, g_env_map, env_name_clean, db_name_lower, context, current_key)
        }

        rule = conditional_rules.get(current_key)
        if rule:
            res_val = rule(current_node, context=parent_dict)
            if isinstance(res_val, str) and any(x in current_key.lower() for x in ['database', 'warehouse']):
                return res_val.upper()
            return res_val
            
        return handle_pattern_fields(current_node, root_metadata, g_env_map, env_name_clean, db_name_lower, parent_dict, current_key)

    return current_node


def get_environment_map(db_name: str, account_url: str, container: str, env_name: str, src_metameta: dict):
    env_name_clean = env_name.strip()
    db_name_lower = db_name.lower() if db_name else ""

    env_map = get_db_environment_map(db_name, account_url, container)
    if env_map:
        ret_env_map = {}
        for key in env_map.keys():
            if env_name_clean in env_map[key]:
                ret_env_map[key] = env_map[key][env_name_clean]
        return ret_env_map

    g_env_map = get_global_environment_map(db_name, account_url, container)
    if not g_env_map:
        return {}

    return replace_recursively(src_metameta, None, g_env_map, env_name_clean, db_name_lower)


