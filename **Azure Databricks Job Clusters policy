For **Azure Databricks Job Clusters**, you typically create a dedicated cluster policy that:

* Allows only `job` cluster type
* Restricts worker size/count
* Forces autotermination
* Prevents all-purpose interactive usage
* Enforces approved DBR versions
* Optionally enables Photon / Unity Catalog

## Terraform Example — Job Cluster Policy

```hcl id="jobcluster01"
terraform {
  required_providers {
    databricks = {
      source  = "databricks/databricks"
    }
  }
}

provider "databricks" {
  host  = var.databricks_host
  token = var.databricks_token
}

resource "databricks_cluster_policy" "job_cluster_policy" {

  name = "job-cluster-policy"

  definition = jsonencode({

    # Allow only job clusters
    "cluster_type" : {
      "type" : "fixed",
      "value" : "job"
    },

    # Auto terminate after 20 mins
    "autotermination_minutes" : {
      "type" : "fixed",
      "value" : 20,
      "hidden" : true
    },

    # Restrict DBR versions
    "spark_version" : {
      "type" : "allowlist",
      "values" : [
        "14.3.x-scala2.12",
        "15.4.x-scala2.12"
      ],
      "defaultValue" : "15.4.x-scala2.12"
    },

    # Restrict VM sizes
    "node_type_id" : {
      "type" : "allowlist",
      "values" : [
        "Standard_DS3_v2",
        "Standard_DS4_v2"
      ],
      "defaultValue" : "Standard_DS3_v2"
    },

    # Restrict worker count
    "num_workers" : {
      "type" : "range",
      "minValue" : 1,
      "maxValue" : 8,
      "defaultValue" : 2
    },

    # Enable Photon
    "runtime_engine" : {
      "type" : "fixed",
      "value" : "PHOTON"
    },

    # Enforce Unity Catalog
    "data_security_mode" : {
      "type" : "fixed",
      "value" : "SINGLE_USER"
    },

    # Prevent users from changing Spark conf
    "spark_conf.spark.databricks.delta.preview.enabled" : {
      "type" : "forbidden"
    }
  })
}
```

