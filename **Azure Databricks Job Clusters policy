## Assign Permissions to Groups

```hcl id="jobcluster02"
resource "databricks_permissions" "job_cluster_policy_usage" {

  cluster_policy_id = databricks_cluster_policy.job_cluster_policy.id

  access_control {
    group_name       = "data-engineers"
    permission_level = "CAN_USE"
  }

  access_control {
    group_name       = "admins"
    permission_level = "CAN_MANAGE"
  }
}
```

---

## Use Policy in Databricks Job

```hcl id="jobcluster03"
resource "databricks_job" "sample_job" {

  name = "daily-etl-job"

  job_cluster {
    job_cluster_key = "etl_cluster"

    new_cluster {
      policy_id = databricks_cluster_policy.job_cluster_policy.id

      num_workers   = 2
      spark_version = "15.4.x-scala2.12"
      node_type_id  = "Standard_DS3_v2"
    }
  }

  task {
    task_key = "etl-task"

    notebook_task {
      notebook_path = "/Shared/etl_notebook"
    }

    job_cluster_key = "etl_cluster"
  }
}
```

