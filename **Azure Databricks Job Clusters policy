You can enforce an **init script** in the Databricks job cluster policy itself using `init_scripts`.

Example with Terraform:

```hcl id="jobclusterinit01"
resource "databricks_cluster_policy" "job_cluster_policy" {

  name = "job-cluster-policy"

  definition = jsonencode({

    # Allow only job clusters
    "cluster_type" : {
      "type" : "fixed",
      "value" : "job"
    },

    # Auto termination
    "autotermination_minutes" : {
      "type" : "fixed",
      "value" : 20,
      "hidden" : true
    },

    # Runtime version
    "spark_version" : {
      "type" : "allowlist",
      "values" : [
        "14.3.x-scala2.12",
        "15.4.x-scala2.12"
      ],
      "defaultValue" : "15.4.x-scala2.12"
    },

    # Node types
    "node_type_id" : {
      "type" : "allowlist",
      "values" : [
        "Standard_DS3_v2",
        "Standard_DS4_v2"
      ]
    },

    # Worker limits
    "num_workers" : {
      "type" : "range",
      "minValue" : 1,
      "maxValue" : 4,
      "defaultValue" : 2
    },

    # Enforce Photon
    "runtime_engine" : {
      "type" : "fixed",
      "value" : "PHOTON"
    },

    # Init Script from DBFS
    "init_scripts.0.dbfs.destination" : {
      "type" : "fixed",
      "value" : "dbfs:/databricks/scripts/init.sh"
    }

  })
}
```

